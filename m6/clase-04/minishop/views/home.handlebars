<section class="mb-4">
    <div class="p-4 bg-light rounded shadow-sm">
        <h1>{{mayusculas nombreTienda}}</h1>
        <p>{{mensajeBienvenida}}</p>
    </div>
</section>

<section>
    <h2 class="mb-4">Productos disponibles</h2>

    <div class="row g-4">
        {{#each productos}}
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <img src="{{imagen}}" class="card-img-top producto-img" alt="{{nombre}}">

                    <div class="card-body">
                        <h3 class="h5">{{nombre}}</h3>
                        <p>Precio: ${{precio}}</p>

                        {{#if disponible}}
                            <span class="badge bg-success">En stock</span>
                        {{else}}
                            <span class="badge bg-danger">Agotado</span>
                        {{/if}}
                    </div>
                </div>
            </div>
        {{/each}}
    </div>
</section>